{
   "name": "@dikolab/create-nx-nestjs-angular",
   "version": "0.0.1",
   "description": "Creates NX, NestJS, Angular mono repo boilerplate",
   "keywords": [
      "NPM",
      "Init"
   ],
   "license": "ISC",
   "author": "Diko Tech Slave",
   "type": "module",
   "main": "./lib/index.js",
   "module": "./lib/index.mjs",
   "types": "./lib/index.d.ts",
   "engines": {
      "typescript": ">=5.1.3"
   },
   "exports": {
      ".": {
         "types": "./lib/index.d.ts",
         "require": "./lib/index.js",
         "import": "./lib/index.mjs"
      }
   },
   "bin": {
      "create-nx-nestjs-angular": "./commands/create-nx-nest-angular.mjs"
   },
   "scripts": {
      "test": "vitest --run",
      "lint": "eslint",
      "lint:fix": "eslint --fix",
      "build": "rollup -c rollup.config.js",
      "prepublishOnly": "npm run lint && npm run test && npm run build"
   }
}
